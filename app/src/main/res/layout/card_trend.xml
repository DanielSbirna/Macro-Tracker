<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="371dp"
    android:layout_height="130dp"
    android:orientation="vertical"
    android:background="@drawable/bg_bordered_container_subtle"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/trendIcon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="@string/trend_icon_desc" />

        <TextView
            android:id="@+id/trendTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="@font/nunito_bold"
            android:textColor="@color/primary_gray_text"
            android:textSize="16sp"
            tools:text="You are crushing it!" />

    </LinearLayout>

    <TextView
        android:id="@+id/trendBody"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/nunito_medium"
        android:textColor="@color/secondary_gray_text"
        android:textSize="14sp"
        tools:text="You've hit the protein goal 5 days in a row. Congratulations!" />

</LinearLayout>
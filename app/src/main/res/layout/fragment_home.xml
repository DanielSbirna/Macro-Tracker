<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".FragmentHome">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Welcome card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/welcomeCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_bordered_bottom_cr20"
                android:padding="20dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageButton
                    android:id="@+id/settingsBtn"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginEnd="10dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/settings"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_settings"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="53dp"
                    android:alpha="0.15"
                    android:contentDescription="@string/decorative_logo"
                    android:rotation="-45"
                    android:scaleType="fitEnd"
                    android:src="@drawable/logo_macro_tracker"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <LinearLayout
                    android:id="@+id/logoRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:layout_width="100dp"
                        android:layout_height="67dp"
                        android:contentDescription="@string/app_logo"
                        android:src="@drawable/logo_macro_tracker" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:fontFamily="@font/nunito_bold"
                        android:text="@string/app_name"
                        android:textColor="@color/primary"
                        android:textSize="16sp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/welcomeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/nunito_bold"
                    android:textColor="@color/primary"
                    android:textSize="16sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/logoRow"
                    tools:text="Welcome back, ready to track?" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:id="@+id/completeAccLayout"
                android:layout_width="371dp"
                android:layout_height="128dp"
                android:layout_margin="10dp"
                android:background="@drawable/bg_bordered_container_subtle"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/welcomeCard">

                <Button
                    android:id="@+id/completeAccBtn"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="270dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_primary_container_cr10"
                    android:drawableLeft="@drawable/ic_account_white"
                    android:drawableRight="@drawable/ic_arrow_right_white"
                    android:fontFamily="@font/nunito_bold"
                    android:letterSpacing="0"
                    android:text="@string/complete_your_account"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    app:backgroundTint="@null" />

                <Button
                    android:id="@+id/EnableNotificationsBtn"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="270dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_primary_container_cr10"
                    android:drawableLeft="@drawable/ic_notifications_white"
                    android:drawableRight="@drawable/ic_arrow_right_white"
                    android:fontFamily="@font/nunito_bold"
                    android:letterSpacing="0"
                    android:text="@string/enable_notifications"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    app:backgroundTint="@null" />
            </LinearLayout>

            <!-- Goal set card -->
            <LinearLayout
                android:id="@+id/goalLayout"
                android:layout_width="371dp"
                android:layout_height="128dp"
                android:layout_margin="10dp"
                android:background="@drawable/bg_bordered_container_subtle"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/welcomeCard">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/current_diet_goal"
                    android:textColor="@color/primary"
                    android:fontFamily="@font/nunito_bold"
                    android:textSize="16sp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/goalChangeBtn"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="270dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_primary_container_cr10"
                    android:fontFamily="@font/nunito_bold"
                    android:letterSpacing="0"
                    android:text="@string/goal_main"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    app:backgroundTint="@null"
                    app:icon="@drawable/ic_edit_white"
                    app:iconGravity="textEnd"
                    app:iconPadding="8dp"
                    app:iconTint="@null" />

            </LinearLayout>

            <!-- Remaining calories card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/remainingCard"
                android:layout_width="194dp"
                android:layout_height="130dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_bordered_container_subtle"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/completeAccLayout">

                <com.example.macrotracker.ui.widgets.CircularProgressView
                    android:id="@+id/remainingCaloriesRing"
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <LinearLayout
                    android:id="@+id/insideText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    app:layout_constraintTop_toTopOf="@id/remainingCaloriesRing"
                    app:layout_constraintBottom_toBottomOf="@id/remainingCaloriesRing"
                    app:layout_constraintStart_toStartOf="@id/remainingCaloriesRing"
                    app:layout_constraintEnd_toEndOf="@id/remainingCaloriesRing">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/remaining"
                        android:textSize="10sp"
                        android:fontFamily="@font/nunito_medium"
                        android:textColor="@color/secondary_gray_text"/>

                    <TextView
                        android:id="@+id/remainingCaloriesValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/nunito_bold"
                        android:text="0,000"
                        android:textColor="@color/primary_gray_text"
                        android:textSize="20sp"/>

                    <TextView
                        android:id="@+id/goalCaloriesValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/nunito_medium"
                        android:text="of 0,000 kcal"
                        android:textColor="@color/secondary_gray_text"
                        android:textSize="11sp" />

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:id="@+id/linearLayout3"
                android:layout_width="371dp"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/remainingCard">

                <com.example.macrotracker.ui.widgets.MacroCardView
                    android:id="@+id/proteinCard"
                    android:layout_width="117dp"
                    android:layout_height="140dp"
                    app:macroLabel="@string/protein" />

                <com.example.macrotracker.ui.widgets.MacroCardView
                    android:id="@+id/carbsCard"
                    android:layout_width="117dp"
                    android:layout_height="140dp"
                    android:layout_marginStart="10dp"
                    app:macroLabel="@string/carbs" />

                <com.example.macrotracker.ui.widgets.MacroCardView
                    android:id="@+id/fatsCard"
                    android:layout_width="117dp"
                    android:layout_height="140dp"
                    android:layout_marginStart="10dp"
                    app:macroLabel="@string/fats" />

            </LinearLayout>

            <include
                android:id="@+id/trendCard"
                layout="@layout/card_trend"
                android:layout_width="371dp"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/linearLayout3" />

            <include
                android:id="@+id/suggestionCard"
                layout="@layout/card_suggestion"
                android:layout_width="371dp"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/trendCard" />

            <com.example.macrotracker.ui.widgets.CalendarStripView
                android:id="@+id/calendarStrip"
                android:layout_width="371dp"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:gravity="center"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/suggestionCard" />

            <LinearLayout
                android:id="@+id/statsRow"
                android:layout_width="371dp"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:orientation="horizontal"
                android:weightSum="4"
                android:divider="@drawable/divider_stat_column"
                android:showDividers="middle"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/calendarStrip"
                app:layout_constraintBottom_toBottomOf="parent">

                <com.example.macrotracker.ui.widgets.StatColumnView
                    android:id="@+id/kcalStat"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:statLabel="@string/kcal" />

                <com.example.macrotracker.ui.widgets.StatColumnView
                    android:id="@+id/proteinStat"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:statLabel="@string/protein_short" />

                <com.example.macrotracker.ui.widgets.StatColumnView
                    android:id="@+id/carbsStat"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:statLabel="@string/carbs_short" />

                <com.example.macrotracker.ui.widgets.StatColumnView
                    android:id="@+id/fatsStat"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:statLabel="@string/fats_short" />

            </LinearLayout>

            <TextView
                android:id="@+id/noMacrosText"
                android:layout_width="371dp"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:gravity="center"
                android:padding="20dp"
                android:text="@string/no_macros_yet"
                android:textColor="@color/secondary_gray_text"
                android:fontFamily="@font/nunito_medium"
                android:textSize="14sp"
                android:background="@drawable/bg_bordered_container_subtle"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/calendarStrip"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
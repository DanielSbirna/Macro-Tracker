<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="371dp"
    android:layout_height="130dp"
    android:orientation="vertical"
    android:background="@drawable/bg_primary_container_cr20"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_light_white"
            android:contentDescription="@string/suggestion_icon_desc" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="@font/nunito_bold"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:text="@string/suggestion" />

    </LinearLayout>

    <TextView
        android:id="@+id/suggestionBody"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/nunito_medium"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:alpha="0.9"
        tools:text="Based on today's logs, you could use a protein snack, like greek yogurt or a protein shake." />

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="5dp"
        android:layout_gravity="center"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_handle"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/update_activity_level"
        android:textSize="20sp"
        android:fontFamily="@font/nunito_bold"
        android:textColor="@color/primary"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:layout_marginBottom="20dp"
        android:text="@string/update_activity_indication"
        android:textColor="@color/secondary_gray_text"/>

    <AutoCompleteTextView
        android:id="@+id/activityDropdown"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bordered_container"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp"
        android:hint="@string/select_activity_level"
        android:fontFamily="@font/nunito_medium"
        android:textColor="@color/primary_gray_text"
        android:textColorHint="@color/secondary_gray_text"
        android:inputType="none"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:cursorVisible="false"
        android:longClickable="false"
        android:drawableEnd="@drawable/ic_dropdown_gray"
        android:drawablePadding="8dp"
        android:completionThreshold="0"
        android:popupBackground="@drawable/bg_bordered_container"
        android:dropDownVerticalOffset="8dp"
        android:dropDownSelector="@drawable/bg_secondary_container"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cancelBtn"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cancel"
            android:textColor="@color/primary"
            android:background="@drawable/bg_secondary_container_cr20"
            app:backgroundTint="@null"
            android:fontFamily="@font/nunito_bold"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/saveBtn"
            style="@style/Widget.Material3.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="@string/save"
            android:background="@drawable/bg_primary_container_cr20"
            app:backgroundTint="@null"
            android:fontFamily="@font/nunito_bold"/>

    </LinearLayout>

</LinearLayout>
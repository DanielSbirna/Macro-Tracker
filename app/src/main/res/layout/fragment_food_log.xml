<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".FoodLogFragment">

    <include
        android:id="@+id/topNav"
        layout="@layout/top_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"/>

    <com.example.macrotracker.ui.widgets.DayNavigatorView
        android:id="@+id/dayNavigator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        android:paddingVertical="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/topNav" />

    <LinearLayout
        android:id="@+id/caloriesCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        android:background="@drawable/bg_bordered_container_subtle"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/dayNavigator">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:text="@string/calories_remaining"
            android:fontFamily="@font/nunito_bold"
            android:textColor="@color/primary"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/caloriesValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_horizontal"
            android:fontFamily="@font/nunito_bold"
            android:textColor="@color/primary"
            android:textSize="32sp" />

        <com.example.macrotracker.ui.widgets.LinearProgressView
            android:id="@+id/caloriesProgress"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:layout_marginTop="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/caloriesPercent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/nunito_medium"
                android:textColor="@color/secondary_gray_text"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/caloriesTarget"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:fontFamily="@font/nunito_medium"
                android:textColor="@color/secondary_gray_text"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Macro row -->
    <LinearLayout
        android:id="@+id/macroBarsRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        app:layout_constraintTop_toBottomOf="@+id/caloriesCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:orientation="vertical"
            android:background="@drawable/bg_bordered_container_subtle"
            android:padding="16dp"
            android:layout_margin="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:text="@string/protein"
                android:textAllCaps="true"
                android:fontFamily="@font/nunito_bold"
                android:textColor="@color/primary_gray_text"
                android:textSize="12sp" />

            <com.example.macrotracker.ui.widgets.LinearProgressView
                android:id="@+id/proteinProgress"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="12dp" />

            <TextView
                android:id="@+id/proteinPercent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:paddingBottom="5dp"
                android:fontFamily="@font/nunito_medium"
                android:textColor="@color/secondary_gray_text"
                android:textSize="12sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:orientation="vertical"
            android:background="@drawable/bg_bordered_container_subtle"
            android:padding="16dp"
            android:layout_margin="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:text="@string/carbs"
                android:textAllCaps="true"
                android:fontFamily="@font/nunito_bold"
                android:textColor="@color/primary_gray_text"
                android:textSize="12sp" />

            <com.example.macrotracker.ui.widgets.LinearProgressView
                android:id="@+id/carbProgress"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="12dp" />

            <TextView
                android:id="@+id/carbPercent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/nunito_medium"
                android:textColor="@color/secondary_gray_text"
                android:paddingBottom="5dp"
                android:textSize="12sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:orientation="vertical"
            android:background="@drawable/bg_bordered_container_subtle"
            android:padding="16dp"
            android:layout_margin="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:text="@string/fats"
                android:textAllCaps="true"
                android:fontFamily="@font/nunito_bold"
                android:textColor="@color/primary_gray_text"
                android:textSize="12sp" />

            <com.example.macrotracker.ui.widgets.LinearProgressView
                android:id="@+id/fatsProgress"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="12dp" />

            <TextView
                android:id="@+id/fatsPercent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/nunito_medium"
                android:textColor="@color/secondary_gray_text"
                android:paddingBottom="5dp"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/foodLogList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingHorizontal="16dp"
        android:layout_margin="10dp"
        app:layout_constraintTop_toBottomOf="@+id/macroBarsRow"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mealCardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_bordered_container_subtle"
    android:clickable="true"
    android:focusable="true"
    android:padding="20dp"
    android:orientation="horizontal">

    <LinearLayout
        android:id="@+id/descriptionTimeLayout"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/mealTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:fontFamily="@font/nunito_bold"
            android:maxLines="1"
            android:textColor="@color/primary_gray_text"
            android:textSize="14sp"
            tools:text="Grilled Chicken Salad" />

        <TextView
            android:id="@+id/mealInputTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:fontFamily="@font/nunito_medium"
            android:textColor="@color/secondary_gray_text"
            android:textSize="12sp"
            tools:text="9:30"/>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/mealMacroLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <TextView
            android:id="@+id/mealKcal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/primary"
            android:fontFamily="@font/nunito_bold"
            android:textSize="14sp"
            tools:text="000 kcal" />

        <TextView
            android:id="@+id/mealMacroLine"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/secondary_gray_text"
            tools:text="P 000 | C 000 | F 000"/>

    </LinearLayout>

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".AssistantFragment">

    <include
        android:id="@+id/topNav"
        layout="@layout/top_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <LinearLayout
        android:id="@+id/assistantLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_bordered_container_subtle"
        android:layout_margin="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/topNav">

        <EditText
            android:id="@+id/inputMealField"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginStart="20dp"
            android:background="@drawable/bg_bordered_container"
            android:hint="@string/assistant_input_hint"
            android:textSize="14sp"
            android:fontFamily="@font/nunito_medium"
            android:inputType="textMultiLine"
            android:gravity="top|start" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/getEstimateBtn"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="10dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_primary_container_cr20"
            android:fontFamily="@font/nunito_bold"
            android:text="@string/get_estimate"
            android:textSize="18sp"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:backgroundTint="@null" />

        <LinearLayout
            android:id="@+id/infoLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_info_blue"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/info_strip"
                android:textColor="@color/primary"
                android:fontFamily="@font/nunito_medium"
                android:textSize="12sp"/>

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/resultLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_bordered_container_subtle"
        android:layout_margin="10dp"
        android:padding="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/assistantLayout">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:gravity="center_horizontal"
            android:text="@string/daily_total_updated"
            android:textSize="14sp"
            android:fontFamily="@font/nunito_bold"
            android:textColor="@color/primary_gray_text" />

        <!-- Calories: full width -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/calories"
            android:fontFamily="@font/nunito_bold"
            android:textColor="@color/primary_gray_text"
            android:textSize="14sp" />

        <com.example.macrotracker.ui.widgets.LinearProgressView
            android:id="@+id/caloriesProgress"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginTop="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/caloriesPercent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/nunito_medium"
                android:textColor="@color/secondary_gray_text"
                android:textSize="12sp"
                tools:text="00.0%" />

            <TextView
                android:id="@+id/caloriesTarget"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:fontFamily="@font/nunito_medium"
                android:textColor="@color/secondary_gray_text"
                android:textSize="12sp"
                tools:text="0,000 kcal" />

        </LinearLayout>

        <!-- Protein: full width -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/protein"
            android:fontFamily="@font/nunito_bold"
            android:textColor="@color/primary_gray_text"
            android:textSize="14sp" />

        <com.example.macrotracker.ui.widgets.LinearProgressView
            android:id="@+id/proteinProgress"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginTop="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/proteinPercent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/nunito_medium"
                android:textColor="@color/secondary_gray_text"
                android:textSize="12sp"
                tools:text="00.0%" />

            <TextView
                android:id="@+id/proteinTarget"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:fontFamily="@font/nunito_medium"
                android:textColor="@color/secondary_gray_text"
                android:textSize="12sp"
                tools:text="0,000 kcal" />

        </LinearLayout>

        <!-- carb & fats 50 50-->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <!-- Carbs column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/carbs"
                    android:fontFamily="@font/nunito_bold"
                    android:textColor="@color/primary_gray_text"
                    android:textSize="14sp" />

                <com.example.macrotracker.ui.widgets.LinearProgressView
                    android:id="@+id/carbProgress"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <TextView
                        android:id="@+id/carbPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/nunito_medium"
                        android:textColor="@color/secondary_gray_text"
                        android:textSize="12sp"
                        tools:text="00.0%" />

                    <TextView
                        android:id="@+id/carbsTarget"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="end"
                        android:fontFamily="@font/nunito_medium"
                        android:textColor="@color/secondary_gray_text"
                        android:textSize="12sp"
                        tools:text="0,000 kcal" />

                </LinearLayout>

            </LinearLayout>

            <!-- Fats column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/fats"
                    android:fontFamily="@font/nunito_bold"
                    android:textColor="@color/primary_gray_text"
                    android:textSize="14sp" />

                <com.example.macrotracker.ui.widgets.LinearProgressView
                    android:id="@+id/fatsProgress"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <TextView
                        android:id="@+id/fatsPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/nunito_medium"
                        android:textColor="@color/secondary_gray_text"
                        android:textSize="12sp"
                        tools:text="00.0%" />

                    <TextView
                        android:id="@+id/fatsTarget"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="end"
                        android:fontFamily="@font/nunito_medium"
                        android:textColor="@color/secondary_gray_text"
                        android:textSize="12sp"
                        tools:text="0,000 kcal" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <include
        android:id="@+id/suggestionCard"
        layout="@layout/card_suggestion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/resultLayout"/>

</androidx.constraintlayout.widget.ConstraintLayout>
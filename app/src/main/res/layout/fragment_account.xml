<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".AccountFragment">

    <include
        android:id="@+id/topNav"
        layout="@layout/top_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/topNav"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:id="@+id/accountLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_bordered_container_subtle"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/account_tab"
                    android:textAlignment="center"
                    android:textColor="@color/primary"
                    android:textSize="20sp"
                    android:fontFamily="@font/nunito_bold"/>

                <ImageView
                    android:id="@+id/accountAvatar"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="20dp"
                    android:src="@drawable/avatar_male"
                    android:contentDescription="@string/account_avatar"/>

                <!-- Name -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp">

                    <TextView
                        android:layout_width="110dp"
                        android:layout_height="wrap_content"
                        android:text="@string/name_tag"
                        android:textColor="@color/primary_gray_text"
                        android:textStyle="bold"
                        android:fontFamily="@font/nunito_medium"/>

                    <TextView
                        android:id="@+id/userName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:text="@string/user_name"
                        android:textColor="@color/primary"
                        android:fontFamily="@font/nunito_medium"/>
                </LinearLayout>

                <!-- Email -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp">

                    <TextView
                        android:layout_width="110dp"
                        android:layout_height="wrap_content"
                        android:text="@string/email"
                        android:textColor="@color/primary_gray_text"
                        android:textStyle="bold"
                        android:fontFamily="@font/nunito_medium"/>

                    <TextView
                        android:id="@+id/userEmail"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:text="@string/user_email"
                        android:textColor="@color/primary"
                        android:fontFamily="@font/nunito_medium"/>
                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/personalInfoLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_bordered_container_subtle"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/user_info_tab"
                    android:textAlignment="center"
                    android:textColor="@color/primary"
                    android:textSize="20sp"
                    android:fontFamily="@font/nunito_bold"/>

                <!-- Height -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="110dp"
                        android:layout_height="wrap_content"
                        android:text="@string/height_tag"
                        android:textColor="@color/primary_gray_text"
                        android:textStyle="bold"
                        android:fontFamily="@font/nunito_medium"/>

                    <TextView
                        android:id="@+id/userHeight"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:text="@string/height_cm"
                        android:textColor="@color/primary"
                        android:fontFamily="@font/nunito_medium"/>

                    <ImageButton
                        android:id="@+id/editHeightBtn"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@android:color/transparent"
                        android:src="@drawable/ic_arrow_right_blue"
                        android:layout_marginStart="10dp"
                        android:contentDescription="@string/edit_height_button"/>

                </LinearLayout>

                <!-- Weight -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="110dp"
                        android:layout_height="wrap_content"
                        android:text="@string/weight_tag"
                        android:textColor="@color/primary_gray_text"
                        android:textStyle="bold"
                        android:fontFamily="@font/nunito_medium"/>

                    <TextView
                        android:id="@+id/userWeight"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:text="@string/weight_kg"
                        android:textColor="@color/primary"
                        android:fontFamily="@font/nunito_medium"/>

                    <ImageButton
                        android:id="@+id/editWeightBtn"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@android:color/transparent"
                        android:src="@drawable/ic_arrow_right_blue"
                        android:layout_marginStart="10dp"
                        android:contentDescription="@string/edit_weight_button"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="110dp"
                        android:layout_height="wrap_content"
                        android:text="@string/birthday_tag"
                        android:textColor="@color/primary_gray_text"
                        android:textStyle="bold"
                        android:fontFamily="@font/nunito_medium"/>

                    <TextView
                        android:id="@+id/userBirthday"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:text="@string/user_birthday"
                        android:textColor="@color/primary"
                        android:fontFamily="@font/nunito_medium"/>

                    <ImageButton
                        android:id="@+id/editBirthdayBtn"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@android:color/transparent"
                        android:src="@drawable/ic_arrow_right_blue"
                        android:layout_marginStart="10dp"
                        android:contentDescription="@string/edit_birthday_button"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="110dp"
                        android:layout_height="wrap_content"
                        android:text="@string/activity_tag"
                        android:textColor="@color/primary_gray_text"
                        android:textStyle="bold"
                        android:fontFamily="@font/nunito_medium"/>

                    <TextView
                        android:id="@+id/userActivity"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:text="@string/user_activity"
                        android:textColor="@color/primary"
                        android:fontFamily="@font/nunito_medium"/>

                    <ImageButton
                        android:id="@+id/editActivityBtn"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@android:color/transparent"
                        android:src="@drawable/ic_arrow_right_blue"
                        android:layout_marginStart="10dp"
                        android:contentDescription="@string/edit_activity_button"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="110dp"
                        android:layout_height="wrap_content"
                        android:text="@string/goal_tag"
                        android:textColor="@color/primary_gray_text"
                        android:textStyle="bold"
                        android:fontFamily="@font/nunito_medium"/>

                    <TextView
                        android:id="@+id/userGoal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:text="@string/goal_bulk"
                        android:textColor="@color/primary"
                        android:fontFamily="@font/nunito_medium"/>

                    <ImageButton
                        android:id="@+id/editGoalBtn"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@android:color/transparent"
                        android:src="@drawable/ic_arrow_right_blue"
                        android:layout_marginStart="10dp"
                        android:contentDescription="@string/edit_goal_button"/>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/goalLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_bordered_container_subtle"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/progress_tab"
                    android:textAlignment="center"
                    android:textColor="@color/primary"
                    android:textSize="20sp"
                    android:fontFamily="@font/nunito_bold"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="110dp"
                        android:layout_height="wrap_content"
                        android:text="@string/started_on"
                        android:textColor="@color/primary_gray_text"
                        android:textStyle="bold"
                        android:fontFamily="@font/nunito_medium"
                        android:layout_marginStart="10dp"/>

                    <TextView
                        android:id="@+id/userStartDay"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:text="@string/start_date"
                        android:textColor="@color/primary"
                        android:fontFamily="@font/nunito_medium"
                        android:layout_marginEnd="10dp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="110dp"
                        android:layout_height="wrap_content"
                        android:text="@string/started_at"
                        android:textColor="@color/primary_gray_text"
                        android:textStyle="bold"
                        android:fontFamily="@font/nunito_medium"
                        android:layout_marginStart="10dp"/>

                    <TextView
                        android:id="@+id/userStartWeight"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:text="@string/start_weight"
                        android:textColor="@color/primary"
                        android:fontFamily="@font/nunito_medium"
                        android:layout_marginEnd="10dp"/>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/deleteLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_bordered_container_subtle"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/danger_zone"
                    android:textAlignment="center"
                    android:textColor="@color/primary"
                    android:textSize="20sp"
                    android:fontFamily="@font/nunito_bold"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/logOutBtn"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_primary_container_cr10"
                    android:text="@string/log_out"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:fontFamily="@font/nunito_bold"
                    android:letterSpacing="0"
                    app:backgroundTint="@null"
                    app:icon="@drawable/ic_logout_white"
                    app:iconGravity="textEnd"
                    app:iconSize="20dp"
                    app:iconTint="@null"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/deleteBtn"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_button_delete"
                    android:text="@string/delete"
                    android:textAllCaps="false"
                    android:textColor="@color/error"
                    android:fontFamily="@font/nunito_bold"
                    android:letterSpacing="0"
                    app:backgroundTint="@null"
                    app:icon="@drawable/ic_delete_red"
                    app:iconGravity="textEnd"
                    app:iconSize="20dp"
                    app:iconTint="@null"/>


            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>